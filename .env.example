# Stripe (test mode ključevi — https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT tajna — OBAVEZNO promijeni (generiraj s: openssl rand -hex 32);
# backend s default vrijednošću glasno upozorava u logu
JWT_SECRET=change-me

# Grafana pristup (default admin/admin je samo za lokalni razvoj)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Opcionalno — Cloudinary za slike (bez ovoga se koristi lokalni disk)
CLOUDINARY_URL=

# Opcionalno — SendGrid za emailove (bez ovoga se emailovi samo logiraju)
SENDGRID_API_KEY=
# Verificirana sender adresa u SendGridu (Single Sender Verification)
EMAIL_FROM=
